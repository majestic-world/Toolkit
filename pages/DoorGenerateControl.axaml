<UserControl x:Class="L2Toolkit.pages.DoorGenerateControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#393939">

    <UserControl.Resources>
        <!-- Ghost button: transparent with border, for secondary actions -->
        <ControlTheme x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderBrush" Value="#565656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
<ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="Background" Value="#3C3C3C"/>
                <Setter Property="BorderBrush" Value="#646464"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#PART_Border">
                <Setter Property="Background" Value="#323232"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBox.Code /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox.Code:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox.Code:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── Page Header ───────────────────────────────────────── -->
            <StackPanel Margin="32,28,32,24" Spacing="3">
                <TextBlock Text="Gerador de Portas"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#E8E8E8"/>
                <TextBlock Text="Converte dados do UnrealEd em XML para Lineage II"
                           FontSize="13"
                           Foreground="#E8E8E8"/>
            </StackPanel>

            <!-- ── Painel 01: Entrada ────────────────────────────────── -->
            <Border Margin="32,0"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">

                    <!-- Accent stripe -->
                    <Border Grid.Column="0" Background="#5B9BD5"/>

                    <StackPanel Grid.Column="1">

                        <!-- Section label row -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="20,14,20,14"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <TextBlock Text="01"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4A88B8"
                                       VerticalAlignment="Center"/>
                            <Border Width="1" Height="18" Background="#565656" VerticalAlignment="Center"/>
                            <TextBlock Text="DADOS DE ENTRADA"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="#464646"/>

                        <!-- Input TextBox -->
                        <TextBox x:Name="InputTextBox"
                                 Classes="Code"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="190"
                                 Padding="20,14"
                                 BorderThickness="0"
                                 Background="#383838"
                                 Foreground="#D4D4D4"
                                 CaretBrush="#5B9BD5"
                                 SelectionBrush="#1E3A5A"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="12"
                                 Watermark="Cole o conteúdo do UnrealEd aqui..."/>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Ação: Converter (separador visual) ───────────────── -->
            <Grid Margin="32,20" ColumnDefinitions="*,Auto,*">
                <Border Grid.Column="0"
                        Height="1"
                        Background="#464646"
                        VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="ConvertButton"
                        Height="40"
                        Padding="28,0"
                        Margin="20,0"
                        Theme="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <PathIcon Data="M8 5v14l11-7z" Width="14" Height="14" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="Converter para XML"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Grid.Column="2"
                        Height="1"
                        Background="#464646"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- ── Painel 02: Saída ──────────────────────────────────── -->
            <Border Margin="32,0,32,32"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">

                    <!-- Accent stripe (dimmed for output = secondary step) -->
                    <Border Grid.Column="0" Background="#5B9BD5"/>

                    <StackPanel Grid.Column="1">

                        <!-- Section label row -->
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                              Margin="20,0"
                              Height="52">

                            <TextBlock Grid.Column="0"
                                       Text="02"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4A88B8"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1"
                                    Width="1" Height="18"
                                    Background="#565656"
                                    VerticalAlignment="Center"
                                    Margin="14,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="XML GERADO"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>

                            <!-- Badge "Copiado!" -->
                            <Border Grid.Column="3"
                                    x:Name="CopyNotification"
                                    IsVisible="False"
                                    Background="#142B1A"
                                    BorderBrush="#245230"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="10,4"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <PathIcon Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Width="10" Height="10" Foreground="#52C97A" VerticalAlignment="Center"/>
                                    <TextBlock Text="Copiado!"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="#52C97A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Copy button -->
                            <Button Grid.Column="4"
                                    x:Name="CopyButton"
                                    Height="30"
                                    Padding="14,0"
                                    VerticalAlignment="Center"
                                    Theme="{StaticResource GhostButton}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <PathIcon Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" Foreground="#9A9A9A" Width="12" Height="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Copiar"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </Grid>

                        <Border Height="1" Background="#464646"/>

                        <!-- Output TextBox -->
                        <TextBox x:Name="OutputTextBox"
                                 Classes="Code"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="190"
                                 Padding="20,14"
                                 BorderThickness="0"
                                 Background="#383838"
                                 Foreground="#9CDCFE"
                                 CaretBrush="#5B9BD5"
                                 SelectionBrush="#1E3A5A"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="12"
                                 IsReadOnly="True"
                                 Watermark="O XML gerado aparecerá aqui..."/>

                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
