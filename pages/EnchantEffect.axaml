<UserControl x:Class="L2Toolkit.pages.EnchantEffect"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#393939">

   <UserControl.Resources>
       <ControlTheme x:Key="GhostButton" TargetType="Button">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="Foreground" Value="#B0B0B0"/>
           <Setter Property="BorderBrush" Value="#565656"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="HorizontalContentAlignment" Value="Center"/>
           <Setter Property="VerticalContentAlignment" Value="Center"/>
           <Setter Property="Template">
               <ControlTemplate>
                   <Border x:Name="PART_Border"
                           Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="6"
                           Padding="{TemplateBinding Padding}">
                       <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         Content="{TemplateBinding Content}"/>
                   </Border>
               </ControlTemplate>
           </Setter>
           <Style Selector="^:pointerover /template/ Border#PART_Border">
               <Setter Property="Background" Value="#3C3C3C"/>
               <Setter Property="BorderBrush" Value="#646464"/>
           </Style>
           <Style Selector="^:pressed /template/ Border#PART_Border">
               <Setter Property="Background" Value="#323232"/>
           </Style>
       </ControlTheme>
       <ControlTheme x:Key="SaveButton" TargetType="Button">
           <Setter Property="Background" Value="#303030"/>
           <Setter Property="Foreground" Value="#C0C0C0"/>
           <Setter Property="BorderBrush" Value="#505050"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="CornerRadius" Value="6"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="HorizontalContentAlignment" Value="Center"/>
           <Setter Property="VerticalContentAlignment" Value="Center"/>
           <Setter Property="Template">
               <ControlTemplate>
                   <Border x:Name="PART_Border"
                           Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="{TemplateBinding CornerRadius}"
                           Padding="{TemplateBinding Padding}">
                       <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         Content="{TemplateBinding Content}"/>
                   </Border>
               </ControlTemplate>
           </Setter>
           <Style Selector="^:pointerover /template/ Border#PART_Border">
               <Setter Property="Background" Value="#3A3A3A"/>
               <Setter Property="BorderBrush" Value="#606060"/>
           </Style>
           <Style Selector="^:pressed /template/ Border#PART_Border">
               <Setter Property="Background" Value="#282828"/>
           </Style>
       </ControlTheme>

       <!-- Mode toggle button themes -->
       <ControlTheme x:Key="ModeButtonActive" TargetType="Button">
           <Setter Property="Background" Value="#1E3049"/>
           <Setter Property="Foreground" Value="#5B9BD5"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="CornerRadius" Value="6"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="HorizontalContentAlignment" Value="Center"/>
           <Setter Property="VerticalContentAlignment" Value="Center"/>
           <Setter Property="Template">
               <ControlTemplate>
                   <Border x:Name="PART_Border"
                           Background="{TemplateBinding Background}"
                           CornerRadius="{TemplateBinding CornerRadius}"
                           Padding="{TemplateBinding Padding}">
                       <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         Content="{TemplateBinding Content}"/>
                   </Border>
               </ControlTemplate>
           </Setter>
           <Style Selector="^:pointerover /template/ Border#PART_Border">
               <Setter Property="Background" Value="#243A54"/>
           </Style>
           <Style Selector="^:pressed /template/ Border#PART_Border">
               <Setter Property="Background" Value="#162840"/>
           </Style>
       </ControlTheme>
       <ControlTheme x:Key="ModeButtonInactive" TargetType="Button">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="Foreground" Value="#6B7280"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="CornerRadius" Value="6"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="HorizontalContentAlignment" Value="Center"/>
           <Setter Property="VerticalContentAlignment" Value="Center"/>
           <Setter Property="Template">
               <ControlTemplate>
                   <Border x:Name="PART_Border"
                           Background="{TemplateBinding Background}"
                           CornerRadius="{TemplateBinding CornerRadius}"
                           Padding="{TemplateBinding Padding}">
                       <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         Content="{TemplateBinding Content}"/>
                   </Border>
               </ControlTemplate>
           </Setter>
           <Style Selector="^:pointerover /template/ Border#PART_Border">
               <Setter Property="Background" Value="#2C2C2C"/>
           </Style>
           <Style Selector="^:pressed /template/ Border#PART_Border">
               <Setter Property="Background" Value="#282828"/>
           </Style>
       </ControlTheme>
   </UserControl.Resources>

   <UserControl.Styles>
       <Style Selector="TextBox.HexInput">
           <Setter Property="Background" Value="#2A2A2A"/>
           <Setter Property="Foreground" Value="#D4D4D4"/>
           <Setter Property="CaretBrush" Value="#5B9BD5"/>
           <Setter Property="SelectionBrush" Value="#1E3A5A"/>
           <Setter Property="BorderBrush" Value="#464646"/>
           <Setter Property="BorderThickness" Value="1"/>
           <Setter Property="CornerRadius" Value="4"/>
           <Setter Property="Padding" Value="6,4"/>
           <Setter Property="FontFamily" Value="Consolas,Courier New,monospace"/>
           <Setter Property="FontSize" Value="12"/>
           <Setter Property="Height" Value="28"/>
       </Style>
       <Style Selector="TextBox.HexInput:focus">
           <Setter Property="BorderBrush" Value="#5B9BD5"/>
       </Style>
       <Style Selector="ComboBox">
           <Setter Property="Background" Value="#2A2A2A"/>
           <Setter Property="Foreground" Value="#D4D4D4"/>
           <Setter Property="BorderBrush" Value="#464646"/>
           <Setter Property="Height" Value="34"/>
       </Style>

       <!-- Slider track style for the color picker -->
       <Style Selector="Slider.PickerSlider">
           <Setter Property="Minimum" Value="0"/>
           <Setter Property="Maximum" Value="255"/>
           <Setter Property="Height" Value="20"/>
       </Style>
       <Style Selector="Slider.PickerSlider /template/ Track">
           <Setter Property="Height" Value="6"/>
       </Style>
       <Style Selector="Slider.PickerSlider /template/ Track#PART_Track Thumb">
           <Setter Property="Width" Value="14"/>
           <Setter Property="Height" Value="14"/>
           <Setter Property="Background" Value="#E8E8E8"/>
           <Setter Property="CornerRadius" Value="7"/>
           <Setter Property="BorderThickness" Value="0"/>
       </Style>
   </UserControl.Styles>

   <Grid>
       <Grid RowDefinitions="Auto,*" Margin="30,28,30,20">
       <StackPanel Grid.Row="0" Spacing="4">

           <!-- Header -->
           <StackPanel Spacing="4">
               <TextBlock Text="Efeito de Encantamento"
                          FontSize="28" FontWeight="Light" Foreground="#E8E8E8"/>
               <TextBlock Text="Editor visual de cores de brilho para armas e armaduras"
                          FontSize="14" Foreground="#9CA3AF"/>
           </StackPanel>

           <!-- Mode toggle -->
           <Border Background="#242424" CornerRadius="8" Padding="4">
               <Grid ColumnDefinitions="*,4,*">
                   <Button x:Name="WeaponModeBtn" Grid.Column="0"
                           Theme="{StaticResource ModeButtonActive}"
                           Click="WeaponMode_Click" Height="30" Padding="16,0">
                       <TextBlock Text="Arma" VerticalAlignment="Center"
                                  FontSize="13" FontWeight="SemiBold"/>
                   </Button>
                   <Button x:Name="ArmorModeBtn" Grid.Column="2"
                           Theme="{StaticResource ModeButtonInactive}"
                           Click="ArmorMode_Click" Height="30" Padding="16,0">
                       <TextBlock Text="Armadura" VerticalAlignment="Center"
                                  FontSize="13" FontWeight="SemiBold"/>
                   </Button>
               </Grid>
           </Border>

           <!-- ═══ WEAPON SECTION ═══ -->
           <StackPanel x:Name="WeaponSection" Spacing="10">

               <!-- File loader -->
               <StackPanel Spacing="8">
                   <TextBlock Text="ARQUIVO" Foreground="#6B7280" FontSize="10"
                              FontWeight="Bold" LetterSpacing="1"/>
                   <Grid ColumnDefinitions="*,12,Auto">
                       <Border Grid.Column="0" Background="#2C2C2C" CornerRadius="6"
                               BorderBrush="#464646" BorderThickness="1" Height="34"
                               Cursor="Hand" PointerPressed="FilePath_OnClick">
                           <TextBox x:Name="FilePath" IsReadOnly="True"
                                    Focusable="False" IsHitTestVisible="False"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#D4D4D4" Padding="10,6" FontSize="13"
                                    VerticalAlignment="Center"
                                    Watermark="Clique para selecionar WeaponEnchantEffectData.dat..."/>
                       </Border>
                       <Button Grid.Column="2" Click="LoadFile_Click"
                               Theme="{StaticResource SaveButton}" Height="34" Padding="16,0">
                           <StackPanel Orientation="Horizontal" Spacing="8">
                               <PathIcon Width="14" Height="14" VerticalAlignment="Center"
                                         Foreground="#C0C0C0"
                                         Data="M6.5 20Q5.1 20 4.05 18.975 3 17.95 3 16.5V8.5Q3 7.05 4.05 6.025 5.1 5 6.5 5H10.5Q10.775 5 10.975 5.2 11.175 5.4 11.175 5.675 11.175 5.95 10.975 6.15 10.775 6.35 10.5 6.35H6.5Q5.65 6.35 5.025 6.975 4.4 7.6 4.4 8.5V16.5Q4.4 17.4 5.025 18.025 5.65 18.65 6.5 18.65H17.5Q18.35 18.65 18.975 18.025 19.6 17.4 19.6 16.5V12.5Q19.6 12.225 19.8 12.025 20 11.825 20.275 11.825 20.55 11.825 20.75 12.025 20.95 12.225 20.95 12.5V16.5Q20.95 17.95 19.9 18.975 18.85 20 17.5 20ZM20.25 6.6 13.85 13Q13.65 13.2 13.375 13.2 13.1 13.2 12.9 13 12.7 12.8 12.7 12.525 12.7 12.25 12.9 12.05L19.3 5.65H16.5Q16.225 5.65 16.025 5.45 15.825 5.25 15.825 4.975 15.825 4.7 16.025 4.5 16.225 4.3 16.5 4.3H20.975Q21.25 4.3 21.45 4.5 21.65 4.7 21.65 4.975V9.45Q21.65 9.725 21.45 9.925 21.25 10.125 20.975 10.125 20.7 10.125 20.5 9.925 20.3 9.725 20.3 9.45V6.6Z"/>
                               <TextBlock Text="Abrir" VerticalAlignment="Center" FontSize="13"/>
                           </StackPanel>
                       </Button>
                   </Grid>
               </StackPanel>

               <!-- Entry selector (hidden until file loaded) -->
               <Grid x:Name="SelectorPanel" IsVisible="False" ColumnDefinitions="*,16,*">
                   <StackPanel Grid.Column="0" Spacing="6">
                       <TextBlock Text="TIPO" Foreground="#6B7280" FontSize="10"
                                  FontWeight="Bold" LetterSpacing="1"/>
                       <ComboBox x:Name="TypeCombo" HorizontalAlignment="Stretch"
                                 SelectionChanged="OnEntrySelectionChanged"/>
                   </StackPanel>
                   <StackPanel Grid.Column="2" Spacing="6">
                       <TextBlock Text="GRAU" Foreground="#6B7280" FontSize="10"
                                  FontWeight="Bold" LetterSpacing="1"/>
                       <ComboBox x:Name="GradeCombo" HorizontalAlignment="Stretch"
                                 SelectionChanged="OnEntrySelectionChanged"/>
                   </StackPanel>
               </Grid>

               <!-- Weapon content (hidden until entry selected) -->
               <StackPanel x:Name="ContentPanel" IsVisible="False" Spacing="10">

                   <!-- Gradient preview bar -->
                   <StackPanel Spacing="6">
                       <TextBlock Text="PRÉVIA — RADIANCE" Foreground="#6B7280" FontSize="10"
                                  FontWeight="Bold" LetterSpacing="1"/>
                       <Border Height="40" CornerRadius="6" ClipToBounds="True">
                           <Grid x:Name="PreviewGrid"/>
                       </Border>
                       <Grid x:Name="PreviewLabelsGrid"/>
                   </StackPanel>

                   <!-- Generator panel -->
                   <Border Background="#2C2C2C" CornerRadius="8" Padding="16">
                       <StackPanel Spacing="14">
                           <TextBlock Text="GERENCIAR GRADIENTE"
                                      Foreground="#6B7280" FontSize="10"
                                      FontWeight="Bold" LetterSpacing="1"/>

                           <Grid>
                               <Grid.ColumnDefinitions>
                                   <ColumnDefinition Width="Auto"/>
                                   <ColumnDefinition Width="8"/>
                                   <ColumnDefinition Width="Auto"/>
                                   <ColumnDefinition Width="*"/>
                                   <ColumnDefinition Width="Auto"/>
                               </Grid.ColumnDefinitions>

                               <!-- Aplicar a todos -->
                               <Button Grid.Column="0" Click="ApplyAll_Click"
                                       Theme="{StaticResource GhostButton}" Height="36" Padding="14,0">
                                   <StackPanel Orientation="Horizontal" Spacing="8">
                                       <PathIcon Width="13" Height="13" VerticalAlignment="Center"
                                                 Foreground="#5B9BD5"
                                                 Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
                                       <TextBlock Text="Aplicar a todos os graus" VerticalAlignment="Center" FontSize="13"/>
                                   </StackPanel>
                               </Button>

                               <!-- Salvar -->
                               <Button x:Name="SaveButton" Grid.Column="4" IsVisible="False"
                                       Click="SaveFile_Click" Height="36" Padding="16,0"
                                       Theme="{StaticResource SaveButton}">
                                   <StackPanel Orientation="Horizontal" Spacing="8">
                                       <PathIcon Width="14" Height="14" VerticalAlignment="Center"
                                                 Foreground="#C0C0C0"
                                                 Data="M12 16L6 10h4V4h4v6h4l-6 6z M4 18h16v2H4z"/>
                                       <TextBlock Text="Salvar Arquivo" VerticalAlignment="Center"
                                                  FontSize="13" FontWeight="SemiBold"/>
                                   </StackPanel>
                               </Button>

                           </Grid>
                       </StackPanel>
                   </Border>

               </StackPanel>

           </StackPanel>

           <!-- ═══ ARMOR SECTION ═══ -->
           <StackPanel x:Name="ArmorSection" IsVisible="False" Spacing="24">

               <!-- Armor file loader -->
               <StackPanel Spacing="8">
                   <TextBlock Text="ARQUIVO" Foreground="#6B7280" FontSize="10"
                              FontWeight="Bold" LetterSpacing="1"/>
                   <Grid ColumnDefinitions="*,12,Auto">
                       <Border Grid.Column="0" Background="#2C2C2C" CornerRadius="6"
                               BorderBrush="#464646" BorderThickness="1" Height="34"
                               Cursor="Hand" PointerPressed="ArmorFilePath_OnClick">
                           <TextBox x:Name="ArmorFilePath" IsReadOnly="True"
                                    Focusable="False" IsHitTestVisible="False"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#D4D4D4" Padding="10,6" FontSize="13"
                                    VerticalAlignment="Center"
                                    Watermark="Clique para selecionar FullArmorEnchantEffectData.dat..."/>
                       </Border>
                       <Button Grid.Column="2" Click="ArmorLoadFile_Click"
                               Theme="{StaticResource SaveButton}" Height="34" Padding="16,0">
                           <StackPanel Orientation="Horizontal" Spacing="8">
                               <PathIcon Width="14" Height="14" VerticalAlignment="Center"
                                         Foreground="#C0C0C0"
                                         Data="M6.5 20Q5.1 20 4.05 18.975 3 17.95 3 16.5V8.5Q3 7.05 4.05 6.025 5.1 5 6.5 5H10.5Q10.775 5 10.975 5.2 11.175 5.4 11.175 5.675 11.175 5.95 10.975 6.15 10.775 6.35 10.5 6.35H6.5Q5.65 6.35 5.025 6.975 4.4 7.6 4.4 8.5V16.5Q4.4 17.4 5.025 18.025 5.65 18.65 6.5 18.65H17.5Q18.35 18.65 18.975 18.025 19.6 17.4 19.6 16.5V12.5Q19.6 12.225 19.8 12.025 20 11.825 20.275 11.825 20.55 11.825 20.75 12.025 20.95 12.225 20.95 12.5V16.5Q20.95 17.95 19.9 18.975 18.85 20 17.5 20ZM20.25 6.6 13.85 13Q13.65 13.2 13.375 13.2 13.1 13.2 12.9 13 12.7 12.8 12.7 12.525 12.7 12.25 12.9 12.05L19.3 5.65H16.5Q16.225 5.65 16.025 5.45 15.825 5.25 15.825 4.975 15.825 4.7 16.025 4.5 16.225 4.3 16.5 4.3H20.975Q21.25 4.3 21.45 4.5 21.65 4.7 21.65 4.975V9.45Q21.65 9.725 21.45 9.925 21.25 10.125 20.975 10.125 20.7 10.125 20.5 9.925 20.3 9.725 20.3 9.45V6.6Z"/>
                               <TextBlock Text="Abrir" VerticalAlignment="Center" FontSize="13"/>
                           </StackPanel>
                       </Button>
                   </Grid>
               </StackPanel>

               <!-- Armor content (hidden until file loaded) -->
               <StackPanel x:Name="ArmorContentPanel" IsVisible="False" Spacing="20">

                   <!-- Preview bar -->
                   <StackPanel Spacing="6">
                       <TextBlock Text="PRÉVIA — MIN COLOR" Foreground="#6B7280" FontSize="10"
                                  FontWeight="Bold" LetterSpacing="1"/>
                       <Border Height="40" CornerRadius="6" ClipToBounds="True">
                           <Grid x:Name="ArmorPreviewGrid"/>
                       </Border>
                       <Grid x:Name="ArmorPreviewLabelsGrid"/>
                   </StackPanel>

                   <!-- Action bar -->
                   <Border Background="#2C2C2C" CornerRadius="8" Padding="16">
                       <StackPanel Spacing="14">
                           <TextBlock Text="AÇÕES"
                                      Foreground="#6B7280" FontSize="10"
                                      FontWeight="Bold" LetterSpacing="1"/>
                           <Grid ColumnDefinitions="*,Auto">
                               <Button x:Name="ArmorSaveButton" Grid.Column="1"
                                       Click="ArmorSaveFile_Click" Height="36" Padding="16,0"
                                       Theme="{StaticResource SaveButton}">
                                   <StackPanel Orientation="Horizontal" Spacing="8">
                                       <PathIcon Width="14" Height="14" VerticalAlignment="Center"
                                                 Foreground="#C0C0C0"
                                                 Data="M12 16L6 10h4V4h4v6h4l-6 6z M4 18h16v2H4z"/>
                                       <TextBlock Text="Salvar Arquivo" VerticalAlignment="Center"
                                                  FontSize="13" FontWeight="SemiBold"/>
                                   </StackPanel>
                               </Button>
                           </Grid>
                       </StackPanel>
                   </Border>

               </StackPanel>

           </StackPanel>

       </StackPanel>

       <!-- Row 1: Dynamic rows (preenche o espaço restante da janela) -->
       <Grid Grid.Row="1" Margin="0,8,0,0">

           <!-- Seção de linhas de arma (visível quando entrada carregada) -->
           <Grid x:Name="WeaponRowsSection" IsVisible="False" RowDefinitions="Auto,*">
               <Grid Grid.Row="0" ColumnDefinitions="52,8,*,12,*,12,60" Margin="0,0,0,4">
                   <TextBlock Grid.Column="2" Text="RADIANCE"
                              Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                   <TextBlock Grid.Column="4" Text="RING"
                              Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                   <TextBlock Grid.Column="6" Text="PART."
                              Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"
                              TextAlignment="Right"/>
               </Grid>
               <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                   <StackPanel x:Name="RowsPanel" Spacing="3"/>
               </ScrollViewer>
           </Grid>

           <!-- Seção de linhas de armadura (visível quando arquivo carregado) -->
           <Grid x:Name="ArmorRowsSection" IsVisible="False" RowDefinitions="Auto,*">
               <Grid Grid.Row="0" ColumnDefinitions="60,8,*,12,*" Margin="0,0,0,4">
                   <TextBlock Grid.Column="0" Text="GRAU MIN."
                              Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                   <TextBlock Grid.Column="2" Text="MIN COLOR"
                              Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                   <TextBlock Grid.Column="4" Text="MÁX COLOR"
                              Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
               </Grid>
               <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                   <StackPanel x:Name="ArmorRowsPanel" Spacing="3"/>
               </ScrollViewer>
           </Grid>

       </Grid>

       </Grid>

   <!-- Success toast notification -->
   <Border x:Name="SuccessToast"
           IsVisible="False"
           Background="#162A1E"
           BorderBrush="#2D6A4A"
           BorderThickness="1"
           CornerRadius="6"
           Padding="14,10"
           Margin="24,0,24,60"
           VerticalAlignment="Bottom"
           ZIndex="100">
       <StackPanel Orientation="Horizontal" Spacing="10">
           <PathIcon Width="14" Height="14"
                     Foreground="#4CAF82"
                     VerticalAlignment="Center"
                     Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
           <TextBlock x:Name="SuccessToastText"
                      Foreground="#A8D5B8"
                      FontSize="13"
                      VerticalAlignment="Center"/>
       </StackPanel>
   </Border>

   <!-- Error alert banner -->
   <Border x:Name="ErrorBanner"
           IsVisible="False"
           Background="#2A0A0A"
           BorderBrush="#6B1A1A"
           BorderThickness="1"
           CornerRadius="6"
           Padding="14,10"
           Margin="24,0,24,24"
           VerticalAlignment="Bottom"
           ZIndex="101">
       <Grid ColumnDefinitions="16,10,*,10,24">
           <PathIcon Grid.Column="0" Width="14" Height="14"
                     Foreground="#E57373"
                     VerticalAlignment="Center"
                     Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
           <TextBlock x:Name="ErrorBannerText"
                      Grid.Column="2"
                      Foreground="#FFAAAA"
                      FontSize="13"
                      TextWrapping="Wrap"
                      VerticalAlignment="Center"/>
           <Border Grid.Column="4"
                   Width="24" Height="24"
                   CornerRadius="4"
                   Cursor="Hand"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   PointerPressed="ErrorBanner_Close">
               <PathIcon Width="11" Height="11"
                         Foreground="#E57373"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
           </Border>
       </Grid>
   </Border>

   <!-- Color picker popup (shared, shown on swatch click) -->
   <Popup x:Name="ColorPickerPopup"
          IsLightDismissEnabled="True"
          Placement="Bottom"
          VerticalOffset="6">
       <Border Background="#252525"
               BorderBrush="#505050"
               BorderThickness="1"
               CornerRadius="10"
               Padding="14"
               BoxShadow="0 8 32 4 #AA000000">
           <StackPanel x:Name="PickerPanel" Width="230" Spacing="10"/>
       </Border>
   </Popup>

   </Grid>
</UserControl>
