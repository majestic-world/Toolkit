<UserControl x:Class="L2Toolkit.pages.SystemMsgColor"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#393939">

    <UserControl.Resources>
        <ControlTheme x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderBrush" Value="#565656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="Background" Value="#3C3C3C"/>
                <Setter Property="BorderBrush" Value="#646464"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#PART_Border">
                <Setter Property="Background" Value="#323232"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="Foreground" Value="#C0C0C0"/>
            <Setter Property="BorderBrush" Value="#505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="Background" Value="#3A3A3A"/>
                <Setter Property="BorderBrush" Value="#606060"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#PART_Border">
                <Setter Property="Background" Value="#282828"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Slider.PickerSlider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="255"/>
            <Setter Property="Height" Value="20"/>
        </Style>
        <Style Selector="Slider.PickerSlider /template/ Track">
            <Setter Property="Height" Value="6"/>
        </Style>
        <Style Selector="Slider.PickerSlider /template/ Track#PART_Track Thumb">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- TextBox hover/focus: darker than input bg #2C2C2C -->
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#212121"/>
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#1C1C1C"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- ── Top fixed area ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="30,18,30,0" Spacing="10">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="1">
                    <TextBlock Text="Cores de Mensagens do Sistema"
                               FontSize="22" FontWeight="Light" Foreground="#E8E8E8"/>
                    <TextBlock Text="Editor de text-color individual por mensagem"
                               FontSize="13" Foreground="#9CA3AF"/>
                </StackPanel>
            </Grid>

            <!-- File loader -->
            <Grid ColumnDefinitions="*,10,Auto">
                <Border Grid.Column="0" Background="#2C2C2C" CornerRadius="6"
                        BorderBrush="#464646" BorderThickness="1" Height="32"
                        Cursor="Hand" PointerPressed="FilePath_OnClick">
                    <TextBox x:Name="FilePath" IsReadOnly="True" Focusable="False"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#D4D4D4" Padding="10,0" FontSize="13"
                             IsHitTestVisible="False"
                             VerticalAlignment="Stretch"
                             VerticalContentAlignment="Center"
                             Watermark="Clique para selecionar o arquivo SystemMsg.dat..."/>
                </Border>
                <Button Grid.Column="2" Click="OpenFile_Click"
                        Theme="{StaticResource SaveButton}" Height="30" Padding="14,0">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                        <PathIcon Width="13" Height="13" VerticalAlignment="Center" Foreground="#C0C0C0"
                                  Data="M20 6h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                        <TextBlock Text="Abrir" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Backup warning banner — hidden after file is loaded -->
            <Border x:Name="BackupWarningBanner"
                    Background="#1E1800" BorderBrush="#4A3800" BorderThickness="1"
                    CornerRadius="6" Padding="14,12">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Width="14" Height="14" VerticalAlignment="Center" Foreground="#D4A017"
                                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                        <TextBlock Foreground="#D4A017" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="Faça um backup antes de editar"/>
                    </StackPanel>
                    <TextBlock Foreground="#9A7510" FontSize="12" TextWrapping="Wrap"
                               Text="Edições incorretas podem corromper o arquivo do cliente. Ao salvar, um backup automático é gerado na mesma pasta com a extensão .dat.bak — mas recomendamos manter uma cópia manual em local seguro."/>
                </StackPanel>
            </Border>

            <!-- Content controls (hidden until loaded) -->
            <StackPanel x:Name="ContentPanel" IsVisible="False" Spacing="8">

                <!-- Stats + actions -->
                <Grid ColumnDefinitions="*,Auto,8,Auto">
                    <TextBlock x:Name="StatsLabel" Grid.Column="0"
                               Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                    <Button x:Name="ClearSelectionBtn" Grid.Column="1" Click="ClearSelection_Click"
                            IsVisible="False"
                            Theme="{StaticResource GhostButton}" Height="30" Padding="12,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Width="11" Height="11" VerticalAlignment="Center"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                            <TextBlock x:Name="ClearSelectionLabel" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SaveBtn" Grid.Column="3" Click="SaveFile_Click"
                            Theme="{StaticResource SaveButton}" Height="30" Padding="14,0">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <PathIcon x:Name="SaveIcon" Width="13" Height="13" VerticalAlignment="Center" Foreground="#C0C0C0"
                                      Data="M12 16L6 10h4V4h4v6h4l-6 6z M4 18h16v2H4z"/>
                            <Grid x:Name="SaveSpinner" Width="14" Height="14"
                                  IsVisible="False" VerticalAlignment="Center">
                                <Ellipse Stroke="#3A3A3A" StrokeThickness="2" Fill="Transparent" Margin="1"/>
                                <Ellipse x:Name="SpinnerArc"
                                         Stroke="#C0C0C0" StrokeThickness="2" Fill="Transparent" Margin="1"
                                         StrokeDashArray="26,9"
                                         RenderTransformOrigin="50%,50%">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock x:Name="SaveLabel" Text="Salvar Arquivo" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Presets -->
                <Border Background="#2C2C2C" CornerRadius="8" Padding="12,10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="PRESETS" Foreground="#6B7280" FontSize="10"
                                   FontWeight="Bold" LetterSpacing="1"/>
                        <WrapPanel x:Name="PresetWrapPanel"/>
                        <Border Height="1" Background="#3A3A3A"/>
                        <Grid ColumnDefinitions="Auto,10,150,10,Auto,10,Auto,8,Auto,8,Auto">
                            <TextBlock Grid.Column="0" Text="NOME" Foreground="#6B7280" FontSize="10"
                                       FontWeight="Bold" LetterSpacing="1" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" x:Name="PresetNameBox"
                                     Background="#2A2A2A" Foreground="#D4D4D4" BorderBrush="#464646"
                                     BorderThickness="1" CornerRadius="4" Padding="8,0" Height="26"
                                     FontSize="12" VerticalContentAlignment="Center"
                                     Watermark="Nome do preset..."/>
                            <StackPanel Grid.Column="4" x:Name="PresetAddPickerHost"
                                        Orientation="Horizontal" VerticalAlignment="Center"/>
                            <Button Grid.Column="6" Click="AddPreset_Click"
                                    Theme="{StaticResource GhostButton}" Height="26" Padding="10,0">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <PathIcon Width="11" Height="11" VerticalAlignment="Center" Foreground="#C0C0C0"
                                              Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/>
                                    <TextBlock Text="Salvar Preset" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="8" Click="OpenColorsModal_Click"
                                    Theme="{StaticResource GhostButton}" Height="26" Padding="10,0">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <PathIcon Width="11" Height="11" VerticalAlignment="Center" Foreground="#C0C0C0"
                                              Data="M12 3 L21 7 L21 17 L12 21 L3 17 L3 7 Z M12 3 L12 21 M3 7 L21 7 M3 17 L21 17"/>
                                    <TextBlock Text="Cores que já existem" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="10" Click="StartL2_Click"
                                    Theme="{StaticResource GhostButton}" Height="26" Padding="10,0">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <PathIcon Width="11" Height="11" VerticalAlignment="Center"
                                              Data="M8 5v14l11-7z" Foreground="#C0C0C0"/>
                                    <TextBlock Text="Start L2" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Search -->
                <Grid ColumnDefinitions="*,8,Auto">
                    <Border Grid.Column="0" Background="#2C2C2C" CornerRadius="6"
                            BorderBrush="#464646" BorderThickness="1" Height="32">
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#D4D4D4" Padding="12,0" FontSize="13"
                                 VerticalContentAlignment="Center"
                                 Watermark="Buscar por ID ou texto da mensagem..."
                                 TextChanged="SearchBox_TextChanged"
                                 KeyDown="SearchBox_KeyDown"/>
                    </Border>
                    <Button Grid.Column="2" Click="SearchBtn_Click"
                            Theme="{StaticResource SaveButton}" Height="32" Padding="14,0">
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                            <PathIcon Width="13" Height="13" VerticalAlignment="Center" Foreground="#C0C0C0"
                                      Data="F0 M10 3 L15 5 L17 10 L15 15 L10 17 L5 15 L3 10 L5 5 Z M10 6 L12.83 7.17 L13.83 10 L12.83 12.83 L10 13.83 L7.17 12.83 L6.17 10 L7.17 7.17 Z M13.5 15.5 L15.5 13.5 L19.5 17.5 L17.5 19.5 Z"/>
                            <TextBlock Text="Pesquisar" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Column headers -->
                <Grid ColumnDefinitions="52,8,22,6,76,6,26,12,*" Margin="12,0,0,0">
                    <TextBlock Grid.Column="0" Text="ID"
                               Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Grid.Column="2" Text="COR"
                               Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Grid.Column="4" Text="HEX"
                               Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    <TextBlock Grid.Column="8" Text="MENSAGEM"
                               Foreground="#6B7280" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                </Grid>

            </StackPanel>
        </StackPanel>

        <!-- ── Scrollable message list ─────────────────────────────────── -->
        <ScrollViewer x:Name="MsgScrollViewer" Grid.Row="1"
                      IsVisible="False"
                      VerticalScrollBarVisibility="Auto"
                      Margin="30,6,30,16">
            <StackPanel Spacing="4">
                <StackPanel x:Name="MsgRowsPanel" Spacing="2"/>
                <TextBlock x:Name="OverflowLabel" IsVisible="False"
                           Text="" Foreground="#6B7280" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Success toast -->
        <Border x:Name="SuccessToast" Grid.Row="1" IsVisible="False"
                Background="#162A1E" BorderBrush="#2D6A4A" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="24,0,24,24"
                VerticalAlignment="Bottom" ZIndex="100">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Width="14" Height="14" Foreground="#4CAF82" VerticalAlignment="Center"
                          Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                <TextBlock x:Name="SuccessToastText" Foreground="#A8D5B8"
                           FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Color picker popup (shared) -->
        <Popup x:Name="ColorPickerPopup" IsLightDismissEnabled="True"
               Placement="Bottom" VerticalOffset="6">
            <Border Background="#252525" BorderBrush="#505050" BorderThickness="1"
                    CornerRadius="10" Padding="14" BoxShadow="0 8 32 4 #AA000000">
                <StackPanel x:Name="PickerPanel" Width="230" Spacing="10"/>
            </Border>
        </Popup>

        <!-- Colors from file modal -->
        <Grid x:Name="ColorsModal" Grid.RowSpan="2" IsVisible="False" ZIndex="300"
              Background="#CC000000" PointerPressed="ColorsModal_OverlayClick">
            <Border Background="#2A2A2A" BorderBrush="#505050" BorderThickness="1"
                    CornerRadius="10" Padding="20" Width="520" MaxHeight="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BoxShadow="0 12 48 8 #BB000000">
                <Grid RowDefinitions="Auto,12,Auto,12,*">

                    <!-- Modal header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Cores no Arquivo" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                            <TextBlock x:Name="ModalSubtitle" FontSize="12" Foreground="#6B7280"/>
                        </StackPanel>
                        <Button Grid.Column="1" Click="CloseColorsModal_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="28" Height="28" Padding="0"
                                Cursor="Hand" VerticalAlignment="Top">
                            <PathIcon Width="12" Height="12" Foreground="#9CA3AF"
                                      Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Row="2" Height="1" Background="#3A3A3A"/>

                    <!-- Color swatches -->
                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="ModalColorsPanel" Margin="0,4,0,0"/>
                    </ScrollViewer>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
