<UserControl x:Class="L2Toolkit.pages.AppSettingsControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#393939">

    <UserControl.Resources>
        <ControlTheme x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderBrush" Value="#565656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="Background" Value="#3C3C3C"/>
                <Setter Property="BorderBrush" Value="#646464"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#PART_Border">
                <Setter Property="Background" Value="#323232"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBox.FormField">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="CaretBrush" Value="#5B9BD5"/>
            <Setter Property="SelectionBrush" Value="#1E3A5A"/>
            <Setter Property="BorderBrush" Value="#464646"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.FormField /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="TextBox.FormField:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#5B9BD5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBox.FormField:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#5E5E5E"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Page Header -->
            <StackPanel Margin="32,28,32,24" Spacing="3">
                <TextBlock Text="Configurações"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#E8E8E8"/>
                <TextBlock Text="Configure os caminhos e preferências do aplicativo"
                           FontSize="13"
                           Foreground="#E8E8E8"/>
            </StackPanel>

            <!-- Panel 01: Assets folder -->
            <Border Margin="32,0"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="#5B9BD5"/>
                    <StackPanel Grid.Column="1">

                        <StackPanel Orientation="Horizontal"
                                    Margin="20,14,20,14"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <TextBlock Text="01"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4A88B8"
                                       VerticalAlignment="Center"/>
                            <Border Width="1" Height="18" Background="#565656" VerticalAlignment="Center"/>
                            <TextBlock Text="PASTA DE ASSETS"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="#464646"/>

                        <StackPanel Margin="20,16,20,20" Spacing="14">
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="#9A9A9A"
                                       LineHeight="20">
                                Alguns módulos dependem de arquivos de dados do cliente Lineage 2 (ex: ItemName, Armorgrp, Weapongrp).
                                Selecione a pasta onde esses arquivos estão localizados.
                            </TextBlock>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Localização da pasta de assets"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           FontWeight="Medium"/>
                                <Grid ColumnDefinitions="*,12,Auto,8,Auto">
                                    <TextBox x:Name="AssetsDirBox"
                                             Grid.Column="0"
                                             Classes="FormField"
                                             IsReadOnly="True"
                                             VerticalContentAlignment="Center"
                                             Height="38"
                                             Padding="12,0"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12"
                                             Watermark="Nenhuma pasta selecionada..."/>
                                    <Button x:Name="SelectAssetsBtn"
                                            Grid.Column="2"
                                            Height="38"
                                            Padding="16,0"
                                            Theme="{StaticResource GhostButton}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Data="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Foreground="#9A9A9A" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Selecionar"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ClearAssetsBtn"
                                            Grid.Column="4"
                                            Height="38"
                                            Padding="14,0"
                                            Theme="{StaticResource GhostButton}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="14" Height="14" VerticalAlignment="Center" Foreground="#9A9A9A"/>
                                            <TextBlock Text="Limpar"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Modules that need assets -->
                            <Border Background="#2A2A2A"
                                    CornerRadius="6"
                                    Padding="14,10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Módulos que utilizam esta pasta:"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#9A9A9A"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="Prime Shop" FontSize="12" Foreground="#B0B0B0"/>
                                        </Border>
                                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="Pesquisar Ícone" FontSize="12" Foreground="#B0B0B0"/>
                                        </Border>
                                        <Border Background="#3A3A3A" CornerRadius="4" Padding="8,4">
                                            <TextBlock Text="Criar MultiSell" FontSize="12" Foreground="#B0B0B0"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Files needed -->
                            <Border Background="#2A2A2A"
                                    CornerRadius="6"
                                    Padding="14,10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Arquivos necessários na pasta:"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#9A9A9A"/>
                                    <StackPanel x:Name="FilesStatusPanel" Orientation="Horizontal" Spacing="6"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
            
            <!-- Panel: L2DAT Build -->
            <Border Margin="32,20,32,0"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="#6B8E5B"/>
                    <StackPanel Grid.Column="1">

                        <StackPanel Orientation="Horizontal"
                                    Margin="20,14,20,14"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <PathIcon Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Width="18" Height="18" Foreground="#6B8E5B" VerticalAlignment="Center"/>
                            <Border Width="1" Height="18" Background="#565656" VerticalAlignment="Center"/>
                            <TextBlock Text="L2DAT BUILD"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="#464646"/>

                        <StackPanel Margin="20,16,20,20" Spacing="14">

                            <TextBlock TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="#9A9A9A"
                                       LineHeight="20">
                                Compila arquivos .txt da pasta de origem em .l2dat na pasta de saída. Somente arquivos na raiz da pasta são processados.
                            </TextBlock>

                            <!-- Source folder -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Pasta de origem (.txt)"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           FontWeight="Medium"/>
                                <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                                    <TextBox x:Name="BuildSourceBox"
                                             Grid.Column="0"
                                             Classes="FormField"
                                             IsReadOnly="True"
                                             Focusable="False"
                                             IsHitTestVisible="False"
                                             VerticalContentAlignment="Center"
                                             Height="34"
                                             Padding="10,0"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12"
                                             Watermark="Nenhuma pasta selecionada..."/>
                                    <Button x:Name="BuildSelectSourceBtn"
                                            Grid.Column="2"
                                            Height="34"
                                            Padding="14,0"
                                            Theme="{StaticResource GhostButton}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <PathIcon Data="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Foreground="#9A9A9A" Width="13" Height="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="Selecionar" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BuildClearSourceBtn"
                                            Grid.Column="4"
                                            Height="34"
                                            Padding="12,0"
                                            Theme="{StaticResource GhostButton}">
                                        <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Width="13" Height="13" Foreground="#9A9A9A"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Output folder -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Pasta de saída (.l2dat)"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           FontWeight="Medium"/>
                                <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                                    <TextBox x:Name="BuildOutputBox"
                                             Grid.Column="0"
                                             Classes="FormField"
                                             IsReadOnly="True"
                                             Focusable="False"
                                             IsHitTestVisible="False"
                                             VerticalContentAlignment="Center"
                                             Height="34"
                                             Padding="10,0"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12"
                                             Watermark="Padrão: exePath/tables"/>
                                    <Button x:Name="BuildSelectOutputBtn"
                                            Grid.Column="2"
                                            Height="34"
                                            Padding="14,0"
                                            Theme="{StaticResource GhostButton}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <PathIcon Data="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" Foreground="#9A9A9A" Width="13" Height="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="Selecionar" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="BuildResetOutputBtn"
                                            Grid.Column="4"
                                            Height="34"
                                            Padding="12,0"
                                            Theme="{StaticResource GhostButton}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <PathIcon Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" Foreground="#9A9A9A" Width="13" Height="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="Padrão" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Compression level -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Nível de compressão"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           FontWeight="Medium"/>
                                <ComboBox x:Name="BuildQualityBox"
                                          Height="34"
                                          MinWidth="180"
                                          HorizontalAlignment="Left"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="Minimum"/>
                                    <ComboBoxItem Content="Medium"/>
                                    <ComboBoxItem Content="High"/>
                                    <ComboBoxItem Content="Maximum"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Progress bar -->
                            <StackPanel x:Name="BuildProgressPanel" IsVisible="False" Spacing="6">
                                <Grid ColumnDefinitions="*,8,Auto">
                                    <ProgressBar x:Name="BuildProgressBar"
                                                 Grid.Column="0"
                                                 Minimum="0" Maximum="100" Value="0"
                                                 Height="6"
                                                 Foreground="#6B8E5B"
                                                 Background="#2A2A2A"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BuildProgressLabel"
                                               Grid.Column="2"
                                               Text="0 / 0"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="BuildCurrentFile"
                                           FontSize="11"
                                           FontFamily="Consolas,Courier New,monospace"
                                           Foreground="#6B7280"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Build button + status -->
                            <Grid ColumnDefinitions="Auto,12,*">
                                <Button x:Name="BuildBtn"
                                        Grid.Column="0"
                                        Height="38"
                                        Padding="20,0"
                                        Theme="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Width="14" Height="14" Foreground="#6B8E5B" VerticalAlignment="Center"/>
                                        <TextBlock Text="Build"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock x:Name="BuildStatusText"
                                           Grid.Column="2"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           IsVisible="False"/>
                            </Grid>

                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel 02: Config file -->
            <Border Margin="32,16,32,32"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="#5B9BD5"/>
                    <StackPanel Grid.Column="1">

                        <StackPanel Orientation="Horizontal"
                                    Margin="20,14,20,14"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <TextBlock Text="02"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4A88B8"
                                       VerticalAlignment="Center"/>
                            <Border Width="1" Height="18" Background="#565656" VerticalAlignment="Center"/>
                            <TextBlock Text="ARQUIVO DE CONFIGURAÇÃO"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="#464646"/>

                        <StackPanel Margin="20,16,20,20" Spacing="14">
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="#9A9A9A">
                                As configurações do aplicativo são salvas em um arquivo local no AppData.
                            </TextBlock>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Localização do arquivo"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           FontWeight="Medium"/>
                                <TextBlock x:Name="ConfigPathText"
                                           FontSize="12"
                                           Foreground="#D4D4D4"
                                           FontFamily="Consolas,Courier New,monospace"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="OpenConfigFolderBtn"
                                        Height="38"
                                        Padding="16,0"
                                        Theme="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Width="14" Height="14" Foreground="#9A9A9A" VerticalAlignment="Center"/>
                                        <TextBlock Text="Abrir pasta de configuração"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="OpenAppFolderBtn"
                                        Height="38"
                                        Padding="16,0"
                                        Theme="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z" Foreground="#9A9A9A" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Abrir pasta do aplicativo"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel: Test DAT (temporary) -->
            <Border Margin="32,0,32,32"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="#D4A54A"/>
                    <StackPanel Grid.Column="1">

                        <StackPanel Orientation="Horizontal"
                                    Margin="20,14,20,14"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <PathIcon Data="M12 2L1 21h22L12 2zm1 16h-2v-2h2v2zm0-4h-2V9h2v5z" Width="18" Height="18" Foreground="#D4A54A" VerticalAlignment="Center"/>
                            <Border Width="1" Height="18" Background="#565656" VerticalAlignment="Center"/>
                            <TextBlock Text="TEST DAT (TEMPORÁRIO)"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="#464646"/>

                        <StackPanel Margin="20,16,20,20" Spacing="14">
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="#9A9A9A"
                                       LineHeight="20">
                                Selecione um arquivo .dat do cliente L2 para descriptografar e salvar como .txt na área de trabalho.
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="TestDatBtn"
                                        Height="38"
                                        Padding="16,0"
                                        Theme="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="M14 6l-1-2H5v17h2v-7h5l1 2h7V6h-6zm4 8h-4l-1-2H7V6h5l1 2h5v6z" Width="14" Height="14" VerticalAlignment="Center" Foreground="#9A9A9A"/>
                                        <TextBlock Text="Test DAT"
                                                   FontSize="13"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock x:Name="DatStatusText"
                                           FontSize="12"
                                           Foreground="#9A9A9A"
                                           VerticalAlignment="Center"
                                           IsVisible="False"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
