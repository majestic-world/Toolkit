<UserControl x:Class="L2Toolkit.pages.Commission"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#5B9BD5"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="TextBoxBorder" Color="#350B0B17"/>
        <SolidColorBrush x:Key="BackgroundGray" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#EF4444"/>

        <ControlTheme x:Key="CleanCopyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="Background" Value="{StaticResource BackgroundGray}"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <TextBlock Text="Commission Tags"
                         FontSize="32"
                         FontWeight="Light"
                         Foreground="{StaticResource TextPrimary}"
                         Margin="0,0,0,8"/>
                <TextBlock Text="Mobius para Lucera"
                         FontSize="16"
                         Foreground="{StaticResource TextSecondary}"/>

                <Border x:Name="NotificacaoBorder"
                       Background="#FEF3C7"
                       BorderBrush="{StaticResource ErrorColor}"
                       BorderThickness="1"
                       CornerRadius="6"
                       Margin="0,20,0,0"
                       Padding="12"
                       IsVisible="False">
                    <TextBlock x:Name="StatusNotificacao"
                             Foreground="#92400E"
                             TextWrapping="Wrap"
                             FontSize="14"/>
                </Border>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,32">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Selecione a pasta Mobius"
                                 FontSize="14"
                                 FontWeight="Medium"
                                 Foreground="{StaticResource TextPrimary}"
                                 Margin="0,0,0,6"/>
                        <Border CornerRadius="6" BorderThickness="1" Padding="1"
                                BorderBrush="{StaticResource TextBoxBorder}">
                            <TextBox x:Name="MobiusFolder"
                                     PointerPressed="ProductionId_OnPreviewMouseDown"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Selecione a pasta Lucera"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,6"/>
                        <Border CornerRadius="6" BorderThickness="1" Padding="1"
                                BorderBrush="{StaticResource TextBoxBorder}">
                            <TextBox x:Name="LuceraFolder"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PointerPressed="MaterialId_OnPreviewMouseDown"
                                     BorderThickness="0"
                                     Padding="10"/>
                        </Border>
                    </StackPanel>

                    <Button x:Name="GenerateData"
                            Content="Gerar"
                            Click="GenerateData_OnClick"
                            Height="48"
                            Theme="{StaticResource PrimaryButton}"
                            FontSize="16"
                            FontWeight="Medium"
                            HorizontalAlignment="Center"
                            MinWidth="120"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Logs de processamento"
                                  FontSize="16"
                                  FontWeight="Medium"
                                  Foreground="{StaticResource TextPrimary}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <Border Background="{StaticResource BackgroundGray}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBox x:Name="LogData"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="200"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="16"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 IsReadOnly="True"/>
                    </Border>
                    <TextBlock x:Name="ClienteCopiadoTextBlock"
                               Text="✓ Copiado!"
                               Foreground="{StaticResource SuccessColor}"
                               FontSize="12"
                               Margin="0,4,0,0"
                               IsVisible="False"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
