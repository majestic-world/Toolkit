<UserControl x:Class="L2Toolkit.pages.PrimeShopGenerator"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#393939">

    <UserControl.Resources>
        <ControlTheme x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderBrush" Value="#565656"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#PART_Border">
                <Setter Property="Background" Value="#3C3C3C"/>
                <Setter Property="BorderBrush" Value="#646464"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#PART_Border">
                <Setter Property="Background" Value="#323232"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>

        <Style Selector="TextBox.FormField">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="CaretBrush" Value="#5B9BD5"/>
            <Setter Property="SelectionBrush" Value="#1E3A5A"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.FormField /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="TextBox.FormField:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#5B9BD5"/>
        </Style>
        <Style Selector="TextBox.FormField:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#5E5E5E"/>
        </Style>

        <Style Selector="TextBox.Code /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox.Code:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox.Code:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#383838"/>
        </Style>

        <!-- ComboBox dark theme -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="#5E5E5E"/>
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="#5B9BD5"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#414141"/>
        </Style>

    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── Page Header ──────────────────────────────────────── -->
            <StackPanel Margin="32,28,32,16" Spacing="3">
                <TextBlock Text="Prime Shop Generator"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#E8E8E8"/>
                <TextBlock Text="Configure e gere produtos para a Prime Shop"
                           FontSize="13"
                           Foreground="#E8E8E8"/>
            </StackPanel>

            <!-- ── Banner de notificação (condicional) ───────────────── -->
            <Border x:Name="NotificacaoBorder"
                    Margin="32,0,32,16"
                    Background="#1F1A0A"
                    BorderBrush="#5C4A00"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10"
                    IsVisible="False">
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0"
                               Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="#D4A017"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               x:Name="StatusNotificacao"
                               Foreground="#D4A017"
                               TextWrapping="Wrap"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Painel 01: Configuração ───────────────────────────── -->
            <Border Margin="32,0"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="#5B9BD5"/>
                    <StackPanel Grid.Column="1">

                        <StackPanel Orientation="Horizontal"
                                    Margin="20,14,20,14"
                                    Spacing="14"
                                    VerticalAlignment="Center">
                            <TextBlock Text="01"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4A88B8"
                                       VerticalAlignment="Center"/>
                            <Border Width="1" Height="18" Background="#565656" VerticalAlignment="Center"/>
                            <TextBlock Text="CONFIGURAÇÃO"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="#464646"/>

                        <StackPanel Margin="20,16,20,20" Spacing="16">

                            <!-- IDs -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="IDs dos itens"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="#9A9A9A"/>
                                <TextBox x:Name="IdsTextBox"
                                         Classes="FormField"
                                         Watermark="ex: 57;35;36;37 (separados por ponto e vírgula)"/>
                            </StackPanel>

                            <!-- Categoria + Tipo -->
                            <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Categoria"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#9A9A9A"/>
                                    <ComboBox x:Name="CategoryComboBox"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="Tipo"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#9A9A9A"/>
                                    <ComboBox x:Name="TypeComboBox"/>
                                </StackPanel>
                            </Grid>

                            <!-- Preço + Quantidade -->
                            <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Preço"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#9A9A9A"/>
                                    <TextBox x:Name="PriceTextBox"
                                             Classes="FormField"
                                             Watermark="ex: 1000"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="Quantidade"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#9A9A9A"/>
                                    <TextBox x:Name="QuantidadeTextBox"
                                             Classes="FormField"
                                             Text="1"/>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Ação: Gerar (separador de pipeline) ──────────────── -->
            <Grid Margin="32,20" ColumnDefinitions="*,Auto,*">
                <Border Grid.Column="0"
                        Height="1"
                        Background="#464646"
                        VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="GerarButton"
                        Height="40"
                        Padding="28,0"
                        Margin="20,0"
                        Theme="{StaticResource SecondaryButton}">
                    <StackPanel Orientation="Horizontal" Spacing="9">
                        <TextBlock Text="&#xE72D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Gerar"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Grid.Column="2"
                        Height="1"
                        Background="#464646"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- ── Outputs 02 + 03 lado a lado ──────────────────────── -->
            <Grid Margin="32,0" ColumnDefinitions="*,16,*">

                <!-- Painel 02: Cliente -->
                <Border Grid.Column="0"
                        CornerRadius="8"
                        Background="#323232"
                        BorderBrush="#464646"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid ColumnDefinitions="4,*">
                        <Border Grid.Column="0" Background="#5B9BD5"/>
                        <StackPanel Grid.Column="1">

                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                  Margin="16,0"
                                  Height="48">
                                <TextBlock Grid.Column="0"
                                           Text="02"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#4A88B8"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Width="1" Height="16"
                                        Background="#565656"
                                        VerticalAlignment="Center"
                                        Margin="12,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="CLIENTE"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#9A9A9A"
                                           LetterSpacing="1.5"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="3"
                                        x:Name="ClienteCopiadoTextBlock"
                                        IsVisible="False"
                                        Background="#142B1A"
                                        BorderBrush="#245230"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="&#xE73E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="9"
                                                   Foreground="#52C97A"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Copiado!"
                                                   FontSize="10"
                                                   FontWeight="Medium"
                                                   Foreground="#52C97A"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button Grid.Column="4"
                                        x:Name="CopiarClienteButton"
                                        Height="28"
                                        Padding="12,0"
                                        VerticalAlignment="Center"
                                        Theme="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Copiar"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="#464646"/>

                            <TextBlock Text="ProductName_Classic-eu.dat"
                                       FontSize="10"
                                       Foreground="#E1E1E1"
                                       Margin="15 5"
                                       FontFamily="Consolas,Courier New,monospace"/>

                            <TextBox x:Name="ClientTextBox"
                                     Classes="Code"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="180"
                                     Padding="16,10"
                                     BorderThickness="0"
                                     Background="#383838"
                                     Foreground="#9CDCFE"
                                     CaretBrush="#5B9BD5"
                                     SelectionBrush="#1E3A5A"
                                     FontFamily="Consolas,Courier New,monospace"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     Watermark="Saída do cliente aparecerá aqui..."/>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Painel 03: Servidor -->
                <Border Grid.Column="2"
                        CornerRadius="8"
                        Background="#323232"
                        BorderBrush="#464646"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid ColumnDefinitions="4,*">
                        <Border Grid.Column="0" Background="#5B9BD5"/>
                        <StackPanel Grid.Column="1">

                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                  Margin="16,0"
                                  Height="48">
                                <TextBlock Grid.Column="0"
                                           Text="03"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#4A88B8"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Width="1" Height="16"
                                        Background="#565656"
                                        VerticalAlignment="Center"
                                        Margin="12,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="SERVIDOR"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#9A9A9A"
                                           LetterSpacing="1.5"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="3"
                                        x:Name="ServidorCopiadoTextBlock"
                                        IsVisible="False"
                                        Background="#142B1A"
                                        BorderBrush="#245230"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="&#xE73E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="9"
                                                   Foreground="#52C97A"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Copiado!"
                                                   FontSize="10"
                                                   FontWeight="Medium"
                                                   Foreground="#52C97A"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button Grid.Column="4"
                                        x:Name="CopiarServidorButton"
                                        Height="28"
                                        Padding="12,0"
                                        VerticalAlignment="Center"
                                        Theme="{StaticResource GhostButton}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Copiar"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="#464646"/>

                            <TextBlock Text="prime_shop.xml"
                                       FontSize="10"
                                       Foreground="#E1E1E1"
                                       Margin="15 5"
                                       FontFamily="Consolas,Courier New,monospace"/>

                            <TextBox x:Name="ServerTextBox"
                                     Classes="Code"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="180"
                                     Padding="16,10"
                                     BorderThickness="0"
                                     Background="#383838"
                                     Foreground="#9CDCFE"
                                     CaretBrush="#5B9BD5"
                                     SelectionBrush="#1E3A5A"
                                     FontFamily="Consolas,Courier New,monospace"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     Watermark="Saída do servidor aparecerá aqui..."/>

                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>

            <!-- ── Painel 04: Logs ───────────────────────────────────── -->
            <Border Margin="32,16,32,32"
                    CornerRadius="8"
                    Background="#323232"
                    BorderBrush="#464646"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="4,*">
                    <Border Grid.Column="0" Background="#5B9BD5"/>
                    <StackPanel Grid.Column="1">

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                              Margin="20,0"
                              Height="52">
                            <TextBlock Grid.Column="0"
                                       Text="04"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4A88B8"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Width="1" Height="18"
                                    Background="#565656"
                                    VerticalAlignment="Center"
                                    Margin="14,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="LOGS"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#9A9A9A"
                                       LetterSpacing="1.5"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="3"
                                    x:Name="ItensCopiadoTextBlock"
                                    IsVisible="False"
                                    Background="#142B1A"
                                    BorderBrush="#245230"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="10,4"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="&#xE73E;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               Foreground="#52C97A"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Copiado!"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="#52C97A"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Button Grid.Column="4"
                                    x:Name="CopiarItensButton"
                                    Height="30"
                                    Padding="14,0"
                                    VerticalAlignment="Center"
                                    Theme="{StaticResource GhostButton}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="&#xE8C8;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Copiar"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Height="1" Background="#464646"/>

                        <TextBox x:Name="ItemsGeneratedTextBox"
                                 Classes="Code"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="140"
                                 Padding="20,14"
                                 BorderThickness="0"
                                 Background="#383838"
                                 Foreground="#D4D4D4"
                                 CaretBrush="#5B9BD5"
                                 SelectionBrush="#1E3A5A"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="12"
                                 IsReadOnly="True"
                                 Watermark="IDs e nomes gerados aparecerão aqui..."/>

                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
